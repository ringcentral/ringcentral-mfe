{
  "name": "@bundler-example/host",
  "version": "0.1.0",
  "scripts": {
    "start:webpack": "webpack-cli serve",
    "start:rspack": "cross-env BUNDLER=rspack rspack serve --config rspack.config.js",
    "build:webpack": "webpack --mode production",
    "build:rspack": "cross-env BUNDLER=rspack rspack build --mode production --config rspack.config.js",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@babel/core": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@rspack/cli": "^1.0.0",
    "@rspack/core": "^1.0.0",
    "@types/react": "^17.0.52",
    "@types/react-dom": "^17.0.18",
    "babel-loader": "^9.1.0",
    "cross-env": "^7.0.3",
    "html-webpack-plugin": "^5.5.0",
    "webpack": "^5.75.0",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.11.1"
  },
  "dependencies": {
    "@bundler-example/remote": "*",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  }
}
